# ─────────────────────────────────────────────────────────────
# StudyOS — environment example. Copy to `.env` and fill in.
# ─────────────────────────────────────────────────────────────

# --- Core ---
APP_ENV=development
APP_SECRET=change-me-to-a-long-random-string
# Used to encrypt user provider API keys at rest (Fernet key, 32 url-safe base64 bytes)
ENCRYPTION_KEY=change-me-generate-with-fernet

# --- Database (Docker Compose defaults) ---
POSTGRES_USER=interviewos
POSTGRES_PASSWORD=interviewos
POSTGRES_DB=interviewos
POSTGRES_HOST=db
POSTGRES_PORT=5432
# App uses async driver; Alembic derives sync URL from these parts.
DATABASE_URL=postgresql+asyncpg://interviewos:interviewos@db:5432/interviewos

# --- Default LLM provider (users configure their own key in Settings) ---
# One of: openai | anthropic | gemini | nvidia | openrouter | ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
# In Docker, reach a host Ollama via host.docker.internal (localhost when run bare).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Local fallback when the active provider is rate-limited ---
ENABLE_LOCAL_FALLBACK=true
FALLBACK_PROVIDER=ollama
FALLBACK_MODEL=llama3.2
FALLBACK_EMBEDDING_MODEL=nomic-embed-text

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
